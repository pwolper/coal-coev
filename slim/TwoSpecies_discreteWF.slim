ticks all hostCOALESCED+1: first() {
	catn("\n--- first() ---");
	
	//cat("host.cachedFitness: "); catn(p1.cachedFitness(NULL));
	infectedHosts = p1.individuals[match(p2.individuals.tag, p1.individuals.pedigreeID)];
	cat("InfectedHosts.pedigreeIDs: "); catn(infectedHosts.pedigreeID);
	
	infectedHosts.fitnessScaling = 1-s;
	cat("infectedHosts.fitnessScaling: "); catn(infectedHosts.fitnessScaling);
	cat("Host.fitnessScaling: "); catn(p1.individuals.fitnessScaling);	
	
}


ticks all hostCOALESCED+1: late() {
	catn("\n--- late() ---");
	
	cat("Host.pedigreeID: "); catn(p1.individuals.pedigreeID);
	cat("Host.tag: "); catn(p1.individuals.tag);
	
	cat("Pathogen.pedigreeID: "); catn(p2.individuals.pedigreeID);
	cat("Pathogen.tag: "); catn(p2.individuals.tag);
	
	pathPedigreeIDs = p2.individuals.pedigreeID;
	pathHostIDs = p2.individuals.tag;
	// change host.tags of offspring to infected/healthy. Apply fitness effects of infection/kill of hosts or recover them. 
	
	
	//	if (p1.individualCount == 0)
	//		stop(host.avatar + " extinct");
	//	if (pathogen.subpopulations.individualCount == 0)
	//		stop(pathogen.avatar + " extinct");
	
	//catn(pathogen.subpopulations.individualCount);
	catn("Checking pathogen fixation...");
	if (pathogen.subpopulations.individualCount == N_host) {
		catn(pathogen.avatar + " fixed in cycle " + community.tick);
		
		pathogens = p2.individuals;
		infectionDict = Dictionary("PathogenPedigreeID", pathogens.pedigreeID, "PathogenHostIDs", pathogens.tag);
		catn(infectionDict);
		
		if (!exists("slimgui")) {
			dir = paste0("trees/discrete_WF/TwoSpecies_discrete_WF" + "_Nhost" + N_host + "_N0pathogen" + N0_pathogen + "_c" + c + "_s" + s + "_" + getSeed());
			catn("Dir: " + dir);
			createDirectory(dir);
			
			hostFile = paste0(dir + "/" + "HostTreeSeq_" + getSeed() + ".trees");
			host.treeSeqOutput(hostFile);
			catn("Host File written:" + hostFile);
			
			pathogenFile = paste0(dir + "/" + "PathogenTreeSeq_" + getSeed() + ".trees");
			pathogen.treeSeqOutput(pathogenFile);
			catn("Pathogen File written: "  + pathogenFile);
		}
		community.simulationFinished();
	}
}

