ticks all 1 early() {
	
	host.addSubpop("p1", N_host, haploid=T);
	p1.individuals.tag = seqLen(N_host);
	cat("Host.tag: "); catn(p1.individuals.tag);
}

ticks all 2: first() {
	catn("\n\n--- first() ---");
	cat("Host.pedigreeID: "); catn(p1.individuals.pedigreeID);
	cat("Host.tag: "); catn(p1.individuals.tag);
	cat("Host.fitnessScaling: "); catn(p1.cachedFitness(NULL));
}

ticks all 1: late() {
	catn("\n--- late() ---");
	cat("Host.pedigreeID: "); catn(p1.individuals.pedigreeID);
	cat("Host.tag: "); catn(p1.individuals.tag);
	//cat("Host.pedigreeID: "); catn(p1.individuals.pedigreeID);
	
	tags = p1.individuals.tag; // host tags to check coalescence in host ("Host burn-in")
	
	if (all(tags == tags[0])) {
		defineConstant("hostCOALESCED", community.tick);
		catn("Host coalesced in tick " + community.tick + "!");
		community.deregisterScriptBlock(self);
	}
}

ticks all hostCOALESCED+1 first(){
	//initial infection in random host once host coalescence is given.
	catn("\n--- first() ---");
	pathogen.addSubpop("p2", N0_pathogen, haploid=T);
	p2.individuals.color = "red"; p2.individuals.age = 1;
	
	newHost = p1.sampleIndividuals(1);
	newHost.color = "red";
	catn("Initial infection in host " + newHost.pedigreeID);
	p2.individuals.tag = newHost.pedigreeID; //tag pathogen with host.pedigreeID
}


